{
  "manifest_version": 3,
  "name": "Accessibility Agent",
  "version": "0.1.0",
  "description": "Voice-driven web navigation agent for non-technical users",
  "permissions": ["scripting", "storage", "tabs", "offscreen", "tts"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["bubble.css"],
    "run_at": "document_end"
  }],
  "action": {
    "default_icon": "icons/icon128.png"
  },
  "web_accessible_resources": [{
    "resources": ["icons/icon128.png"],
    "matches": ["<all_urls>"]
  }],
  "options_page": "options.html"
}